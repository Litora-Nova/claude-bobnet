# dev-team.env — Projekt-Instanz-Konfig für die claude-bobnet-Scripts.
# Kopieren nach <projekt>/_dev_team/dev-team.env und `source`-en (oder ins Onboard).
# Die Engine bleibt generisch; konkrete Werte leben hier (pro Projekt/Maschine).

# Projekt-Identität (für Sync-Reminder, registry, Heartbeat-Texte):
export PROJECT_NAME="Acme Inc"
# Unveränderliche, kurze, beschreibende Projekt-UID (z.B. acme). Für Branch-Prefixes/Registry/
# Dashboard-projectId/Heartbeat-Routing/Namespacing. NIE ändern — der mutable Display-Name ist
# PROJECT_NAME (z.B. Acme Inc). UID bleibt stabil, auch wenn das Projekt umbenannt wird.
export PROJECT_UID="acme"
# Repo-Root des Projekts (alle relativen Pfade hängen daran; Onboard generiert das absolut):
export PROJECT_ROOT="$HOME/Sites/<project>"

# Geteilte Commit-Email für ALLE Agenten dieses Projekt-Bobiverse (Commit-Authorship-Konvention,
# siehe team-rules/commits.md). Die Identität ist "<Name> (<PROJECT_NAME> <role>) <DEV_TEAM_EMAIL>";
# scripts/git-identity.sh resolved Name+role aus theme.json. EINE Email für alle (kein per-Agent-Split).
export DEV_TEAM_EMAIL="team@litora-nova.com"
# Theme-Slug (themes/<THEME>/theme.json) — Quelle für Persona-Name + Rollen-Label in der Commit-Identität.
export THEME="bobiverse"
# Externes Themes-Verzeichnis (user-seitig, z.B. eigenes Theme-Repo) — Suchpfad VOR den
# Engine-Builtins; Pendant zum Dashboard-NUXT_THEMES_DIR. Leer = nur Engine-Themes.
# export THEMES_DIR="$HOME/Sites/<user-themes-repo>/themes"
# team.config.json (per-Team-Namens-Override für Commits, members[].name keyed by id) —
# Default: $STANDUP_DIR/team.config.json; nur setzen, wenn sie woanders liegt.
# export TEAM_CONFIG="$STANDUP_DIR/team.config.json"

# Wo die Heartbeat-Logs + Inbox + qa/ liegen (committed, pro Projekt):
export STANDUP_DIR="$HOME/Sites/<project>/_dev_team/standup"

# Secrets (NIE committen, out-of-band): telegram_token, telegram_chat_id, telegram_offset
export SCUT_SECRETS_DIR="$HOME/Sites/<project>/.secrets"

# Terminal-Multiplexer (Daemons/Sessions laufen hierin). Die Engine ist neutral:
#   tmux   = klassisch | zellij = moderner Multiplexer | auto = tmux falls da, sonst zellij
# Wird i. d. R. bei der Erstinstallation abgefragt (init-bobs). Default (leer) = auto.
export BOBNET_MUX="auto"               # tmux | zellij | auto

# SCUT / Telegram-Routing
export SCUT_MUX_TARGET="acme_bob"      # Multiplexer-Session des Team-Leads (Alias: SCUT_TMUX_TARGET)
export SCUT_PREFIX="[SCUT/Owner]"      # Inject-Prefix (Lead erkennt Mensch-Input)
export TEAM_LEAD="Bob"                  # Inbox-@-Empfänger
export QA_ASKED_BY="Owner"
export QA_ANSWERED_BY="Bob"

# Wohin scut-poll.sh empfangene Telegram-Media (Bilder/Voice/Docs/…) lädt.
# Default = <STANDUP_DIR>/../_inbox (also _inbox neben standup im Projekt-Repo).
export SCUT_INBOX="$HOME/Sites/<project>/_inbox"

# scut-morning.sh — Override-Texte für Morgen-Ping + Reminder (sonst generische Defaults).
# export SCUT_MORNING_PING="Guten Morgen! …"
# export SCUT_MORNING_REMIND="Reminder: noch keine Antwort — alles ok? …"

# cron/cron-health.sh — Staging-Host (HTTPS-200 + SSL-Restlaufzeit) + BobNet-Endpoint
export HEALTH_HOST="staging.example.com"
export BOBNET_URL="http://localhost:3030"

# bin/sync + cron/cron-bugcheck.sh — Repos für sync/npm-audit (Space-Liste, relativ zu PROJECT_ROOT).
# "." = das Projekt-Repo selbst (acme-docs). bin/sync fetch+pull+push über jeden Eintrag.
export DEV_TEAM_REPOS="acme_backend acme_frontend acme_website"

# bin/sync — Soll-Branch pro Repo für den Branch-Drift-Check (siehe team-rules/sync.md).
export CANONICAL_BRANCH="claude"

# AI-Provider für Spawns (ai-bobnet): claude | devin | codex | cursor
# Default = claude (Claude-Code). Model/Effort pro Rolle werden aus archetypes/<id>.json
# (providers.<BOBNET_PROVIDER>) oder top-level model/effort aufgeloest.
export BOBNET_PROVIDER="claude"

# Optional: globale Model-/Effort-Override (ueberschreibt ALLE Archetypen).
# export BOBNET_MODEL_OVERRIDE="sonnet"
# export BOBNET_EFFORT_OVERRIDE="high"

# cron/cron-standup.sh + cron-recap.sh — Persona für die claude -p Zusammenfassung
export LEAD_PERSONA="Team-Lead"         # ergibt "Du bist <TEAM_LEAD>, <LEAD_PERSONA>."
export LEAD_SIGNOFF="Gute Nacht, Keule. 🐻"   # Recap-Abschluss-Gruß

export DEV_TEAM_TZ="Europe/Berlin"

# Engine-Schema-Version, gegen die diese Instanz onboardet wurde. bin/onboard setzt den aktuellen
# Wert (Engine-SCHEMA_VERSION) beim Generieren; bin/check-compat / bin/upgrade vergleichen dagegen.
export ENGINE_SCHEMA="1"
