#!/usr/bin/env bash
# bin/upgrade [PROJECT_ROOT] — Engine aktualisieren + referenzierte Mechanik refreshen.
#
# Instanz-State bleibt GARANTIERT unangetastet: _dev_team/standup, dev-team.env, agents/*, memories-Inhalt.
#   referenziert (Symlink: skills/memory/team-rules) → Update schlägt via git pull sofort durch
#   generiert    (Hook-Wrapper)                      → bin/onboard erzeugt sie idempotent neu
#   copy-once    (agents/*)                          → bin/onboard fasst sie nur an, wenn leer
#   Instanz-State(env/standup/memories)              → NIE angefasst
set -euo pipefail

ENGINE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECT_ROOT="${1:-${PROJECT_ROOT:-$PWD}}"
echo "=== bobnet upgrade (engine: $ENGINE_ROOT, projekt: $PROJECT_ROOT) ==="

# 1) Engine ziehen (ff-only, wie bin/sync — kein Merge/Rebase/Force)
br="$(git -C "$ENGINE_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo master)"
if git -C "$ENGINE_ROOT" pull --ff-only origin "$br"; then
  echo "  ✓ Engine aktualisiert (origin/$br, v$(cat "$ENGINE_ROOT/VERSION" 2>/dev/null || echo '?'))"
else
  echo "  ✗ Engine-pull fehlgeschlagen (divergiert/offline) — Upgrade gestoppt." >&2; exit 1
fi

# 2) Kompat-Check VOR dem Re-Onboard (brechender Schema-Skew → Stopp statt still kaputt)
if ! "$ENGINE_ROOT/bin/check-compat" "$PROJECT_ROOT"; then
  echo "  → Schema-Skew: Re-Onboard NICHT ausgeführt. Migration nötig (siehe Meldung oben)." >&2; exit 5
fi

# 3) Surface erkennen (Kanon-Drift-Fix 2026-07-17): bin/onboard-codex legt .codex/ an, das
#    klassische bin/onboard legt .claude/ an — dieselbe Marker-Logik, kein neuer Mechanismus.
#    Default bleibt der klassische Onboarder (auch ohne jede Surface-Spur, z. B. Upgrade vor dem
#    ersten Onboard) — ein rein codex-onboardetes Projekt (nur .codex/, kein .claude/) ruft NUR
#    onboard-codex; ist ein Projekt an beiden Surfaces onboarded, refresht upgrade beide idempotent.
run_classic=1
[ -d "$PROJECT_ROOT/.codex" ] && [ ! -d "$PROJECT_ROOT/.claude" ] && run_classic=0

echo "[Re-Onboard]"
if [ "$run_classic" = 1 ]; then
  "$ENGINE_ROOT/bin/onboard" "$PROJECT_ROOT"
fi
if [ -d "$PROJECT_ROOT/.codex" ]; then
  "$ENGINE_ROOT/bin/onboard-codex" "$PROJECT_ROOT"
fi
echo "✓ upgrade fertig."
